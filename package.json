{
  "name": "@almadar/patterns",
  "version": "2.5.0",
  "description": "Pattern registry and component mappings for Almadar",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./registry.json": "./dist/registry.json",
    "./patterns-registry.json": "./dist/patterns-registry.json",
    "./integrators-registry.json": "./dist/integrators-registry.json",
    "./component-mapping.json": "./dist/component-mapping.json",
    "./event-contracts.json": "./dist/event-contracts.json"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "build:watch": "tsup --watch",
    "test": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm run build",
    "prepare": "git config core.hooksPath .githooks"
  },
  "devDependencies": {
    "eslint": "10.0.0",
    "@typescript-eslint/parser": "8.56.0",
    "@almadar/eslint-plugin": ">=2.3.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.4.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/almadar-io/almadar.git",
    "directory": "docs/packages/patterns"
  },
  "license": "MIT",
  "keywords": [
    "almadar",
    "patterns",
    "ui",
    "registry"
  ],
  "homepage": "https://github.com/almadar-io/almadar#readme"
}
